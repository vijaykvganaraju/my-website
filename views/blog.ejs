<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="theme-color" content="#000000" />
    <meta name="keywords" content="Vijay Kumar Varma Ganaraju, Vijay Ganaraju, blogs, thoughts, opinions, updates" />
    <meta name="description" content="A blog page of Vijay Ganaraju about his thoughts, opions, findings, information, updates etc." />


    <title>Blogs</title>
    
    <link rel="manifest" href="/manifest.webmanifest">
    <link rel="apple-touch-icon" href="/assets/img/logo/black_bgw_192.png">
    <link rel="icon" href="/assets/img/logo/White30.png" type="image/x-icon">

    <link rel="stylesheet" href="/assets/styles/common.css">
    <link rel="stylesheet" href="/assets/styles/blog.css">
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
</head>

<body>
    <%- include('partials/header') %>
    
    <main id="container" class="container limit-page">
        <header class="nav-top small-frc">
            <h1 class="page-title">Blog</h1>
        </header>
        <section class="blogs-div">
            <% if(!blogAvailability) { %>
                    <h2 class="headiing">No blogs to show.</h2>
                <% } else {
                blogs.forEach(blog => {  %>
                    <div class="blog-preview">
                        <h2 class="heading"><%= blog.title %></h2>
                        <p class="datetime"><%= blog.datetime.toLocaleString('en-US', dateOptions) %></p>
                        <p class="subject"><%= blog.subject %></p>
                        <div class="tags-div">
                            <% blog.tags.forEach(tag => { %>
                            <a href="/blog/tag/<%= tag %>" class="tag"><%= tag %></a>
                            <% }); %>
                        </div>
                        <div class="read-more-div">
                            <a class="read-more" href="/blog/<%= blog.slug %>">Read more <img src="/assets/img/icons/blog/trending_flat.png" alt="Goto"></a>
                        </div>
                    </div>
                <% }); } %> 
        </section>

        <section class="pages-navigation">
            <% if(pagesData.next)  { %>
                <div class="next-div stretch"><a href="/blog/next" class="next-link"><img src="/assets/img/icons/blog/trending_flat_left.png" alt="left arrow">Next</a></div>
            <% } %>
            <% if(pagesData.prev) { %>
                <div class="prev-div stretch"><a href="/blog/prev" class="prev-link">Prev<img src="/assets/img/icons/blog/trending_flat.png" alt="right arrow"></a></div>
            <% } %>
        </section>

    </main>
    
    <%- include('partials/footer') %>

    <!-- scripts -->
    <script src="/assets/scripts/common.js"></script>
    <script src="/assets/scripts/blog.js"></script>

</body>

</html>
